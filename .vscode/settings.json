{
    "editor.formatOnSave": true,
    "search.exclude": {
        "examples": true,
        "libraries": true
    },
    "terminal.integrated.env.linux": {
        "PATH": "${workspaceFolder}/tools/tasks:${env:PATH}",
    },
    "terminal.integrated.defaultProfile.linux": "bash",
    "git.postCommitCommand": "push",
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}/build"
    ],
    "C_Cpp.intelliSenseEngine": "default",
    "cmake.useCMakePresets": "always",
    "cmake.loggingLevel": "debug",
    "editor.minimap.enabled": false,
    "cmake.options.advanced": {
        "build": {
            "statusBarVisibility": "hidden"
        },
        "launch": {
            "statusBarVisibility": "visible"
        },
        "debug": {
            "statusBarVisibility": "visible"
        },
        "cpack": {
            "statusBarVisibility": "hidden"
        },
        "workflow": {
            "statusBarVisibility": "hidden"
        },
        "workflowPreset": {
            "statusBarVisibility": "hidden"
        },
        "packagePreset": {
            "statusBarVisibility": "hidden"
        },
        "testPreset": {
            "statusBarVisibility": "hidden"
        },
        "buildTarget": {
            "statusBarVisibility": "visible"
        },
        "buildPreset": {
            "statusBarVisibility": "hidden"
        }
    },
    "cmake.options.statusBarVisibility": "visible",
    "debug.showInStatusBar": "never",
    "actionButtons": {
        "defaultColor": "#ff0034", // Can also use string color names.
        "loadNpmCommands": false, // Disables automatic generation of actions for npm commands.
        "reloadButton": "🔄", // Custom reload button text or icon (default ↻). null value enables automatic reload on configuration change
        "commands": [
            {
                "cwd": "", // Terminal initial folder ${workspaceFolder} and os user home as defaults
                "name": "🧹Clean",
                "color": "#F44336",
                "singleInstance": true,
                "useVsCodeApi": true,
                "command": "cmake.clean",
            },
            {
                "cwd": "",
                "name": "▶️ Run",
                "color": "#2196F3",
                "singleInstance": true,
                "useVsCodeApi": true,
                "command": "workbench.action.tasks.runTask",
                "args": [
                    "run.sh"
                ]
            },
            {
                "cwd": "",
                "name": "🚀 Release",
                "color": "#9C27B0",
                "singleInstance": true,
                "useVsCodeApi": true,
                "command": "workbench.action.tasks.runTask",
                "args": [
                    "release.sh"
                ]
            },
            {
                "cwd": "", // Terminal initial folder ${workspaceFolder} and os user home as defaults
                "name": "🧱 Build",
                "color": "#4CAF50",
                "useVsCodeApi": true,
                "command": "workbench.action.tasks.runTask",
                "args": [
                    "build.sh"
                ]
            },
            {
                "cwd": "", // Terminal initial folder ${workspaceFolder} and os user home as defaults
                "name": "🧩 Dependences",
                "color": "#FFC107",
                "singleInstance": true,
                "command": "dependences.sh"
            },
            {
                "cwd": "", // Terminal initial folder ${workspaceFolder} and os user home as defaults
                "name": "🌐 OC Web",
                "color": "#3F51B5",
                "singleInstance": true,
                "useVsCodeApi": true,
                "command": "workbench.action.tasks.runTask",
                "args": [
                    "run_opencode_web_gui.sh"
                ]
            }
        ],
    },
    "files.associations": {
        "*.cs": "csharp",
        "array": "cpp",
        "any": "cpp",
        "string_view": "cpp",
        "ranges": "cpp",
        "span": "cpp",
        "regex": "cpp",
        "thread": "cpp",
        "chrono": "cpp",
        "cctype": "cpp",
        "clocale": "cpp",
        "cmath": "cpp",
        "csignal": "cpp",
        "cstdarg": "cpp",
        "cstddef": "cpp",
        "cstdio": "cpp",
        "cstdlib": "cpp",
        "cstring": "cpp",
        "ctime": "cpp",
        "cwchar": "cpp",
        "cwctype": "cpp",
        "atomic": "cpp",
