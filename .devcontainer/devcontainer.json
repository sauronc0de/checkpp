{
  "name": "🐳[${localWorkspaceFolderBasename}]",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "WORKSPACE_DIR": "/workspaces/${localWorkspaceFolderBasename}",
      "PROJECT_NAME": "${localWorkspaceFolderBasename}"
    }
  },
  "containerEnv": {
    "ENGRAM_DATA_DIR": "${containerWorkspaceFolder}/.engram" // Path where the Engram database is stored. Should be located inside the workspace folder so data persists across container rebuilds.
  },
  "mounts": [
    // Load OpenCode credentials and settings from host.
    "source=${localEnv:HOME}/.local/share/opencode,target=/home/sauroncode/.local/share/opencode,type=bind",
    "source=${localEnv:HOME}/.config/opencode,target=/home/sauroncode/.config/opencode,type=bind"
  ],
  "postStartCommand": "sudo chown -R sauroncode:sauroncode /workspaces/${localWorkspaceFolderBasename} && chmod +x .devcontainer/docker_entrypoint.sh && .devcontainer/docker_entrypoint.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "mhutchie.git-graph",
        "ms-vscode.cmake-tools",
        "ms-azuretools.vscode-docker",
        "aaron-bond.better-comments",
        "seunlanlege.action-buttons",
        "ms-vscode.makefile-tools",
        "vadimcn.vscode-lldb",
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "jebbs.plantuml",
        "bierner.markdown-mermaid",
        "slevesque.shader"
      ]
    }
  }
}